---
interface Props {
  data: Record<string, any>;
}

const { data } = Astro.props;
---

{
  Object.entries(data).map(([key, item]) => (
    <div class="max-w-6xl mx-auto mt-8 px-2 rounded-3xl">
      <div class="bg-secondary rounded-2xl shadow-xl border border-blue-800 overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-2 shadow-xl">
          <div class="relative aspect-[4/3] md:aspect-auto md:h-full">
            <iframe
              src={item.link_mapa}
              class="absolute inset-0 w-full h-full shadow-xl"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            />
          </div>

          <div class="px-4 py-1 flex flex-col justify-center">
            <h3 class="text-xl font-bold text-white mb-4">{item.title}</h3>
            {item.parrafos &&
              Object.entries(item.parrafos).map(([key, parrafos]: any) => (
                <p class="text-sm text-neutral-100 leading-relaxed mb-4">
                  {parrafos}
                </p>
              ))}
            <div class="p-4 flex flex-wrap gap-3">
              {item.items &&
                Object.entries(item.items).map(([key, items]: any) => (
                  <span class="p-2 text-xs font-semibold rounded-2xl bg-gray-100 text-gray-700">
                    {items}
                  </span>
                ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  ))
}
